use v6;
# Register the model cache dir in the repo chain before any Agrammon::* load.
# Required by load-model-using-cache; see lib/Agrammon/ModelCache.rakumod for
# the 2026.04 compunit-identity gotcha that drove this.
use lib %*ENV<HOME> ~ '/.agrammon';

use Test;
use Data::Dump::Tree;
use Agrammon::DataSource::CSV;
use Agrammon::Model;
use Agrammon::ModelCache;
use Agrammon::Model::Parameters;
use Agrammon::OutputFormatter::CSV;
use Agrammon::OutputFormatter::JSON;
use Agrammon::OutputFormatter::Text;
use Agrammon::TechnicalParser;
use Agrammon::Validation;

my $temp-dir = $*HOME.add('.agrammon');

my $input-csv = 'complex-model-run-input.csv';

for <version6.5.2 version7.0.0> -> $model-version {
    subtest "Model $model-version" => {
        my $fh = open $*PROGRAM.parent.add("test-data/$input-csv");
        my @datasets = Agrammon::DataSource::CSV.new().read($fh);
        is @datasets.elems, 1, "Got the one expected data set from $input-csv to run";
        my $dataset = @datasets[0];
        $fh.close;

        my $path = $*PROGRAM.parent.add("../share/Models/$model-version/");
        my $model;
        lives-ok { $model = load-model-using-cache($temp-dir, $path, 'Total') },
                "Load module Total from $path";

        my @validation-errors;
        lives-ok { @validation-errors = validation-errors($model, $dataset) },
                'Performed validation of the inputs against the model';
        for @validation-errors -> $error {
            note $error.message;
        }
        is @validation-errors.elems, 0, 'There are no validation errors';
    }
}

done-testing;
