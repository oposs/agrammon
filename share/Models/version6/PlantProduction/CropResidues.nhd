*** technical ***

+er_sugarbeet_leaves
  value = 5
  ++units  
    en = kg N/ha/year
  ++description
    todo

+er_vegetable_residues
  value = 4.5
  ++units  
    en = kg N/ha/year
  ++description
    todo

+er_green_manure
  value = 4
  ++units  
    en = kg N/ha/year
  ++description
    todo

+er_meadow_residues
  value = 0.75
  ++units  
    en = kg N/ha/year
  ++description
    todo

+er_pasture_mulch
  value = 0.7
  ++units  
    en = kg N/ha/year
  ++description
    todo

*** external ***



*** output ***

+nh3_nsugarbeet_leaves
  print = 15
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    NH3 emission from sugar beet residues.
  ++formula
    In(sugarbeet_leaves) * Tech(er_sugarbeet_leaves);

+nh3_nvegetable_residues
  print = 15
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    NH3 emission from open-field vegetable residues.
  ++formula
    In(vegetable_residues) * Tech(er_vegetable_residues);

+nh3_ngreen_manure
  print = 15
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    NH3 emission from green manure.
  ++formula
    In(green_manure) * Tech(er_green_manure);

+nh3_nmeadow_residues
  print = 15
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    NH3 emission from meadow residues.
  ++formula
    In(meadow_residues) * Tech(er_meadow_residues);

+nh3_npasture_mulch
  print = 15
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    NH3 emission from pasture (mulched area) residues.
  ++formula
    In(pasture_mulch) * Tech(er_pasture_mulch);

+nh3_ncropresidues
  print = SummaryPlantProduction,ResultsPlantProduction,PlantNH3
  ++units  
    en = kg N/year
    de = kg N/Jahr
    fr = kg N/an
  ++description
    Total NH3 emission from crop residues.
  ++formula
    Out(nh3_nsugarbeet_leaves) +
    Out(nh3_nvegetable_residues) +
    Out(nh3_ngreen_manure) +
    Out(nh3_nmeadow_residues) +
    Out(nh3_npasture_mulch);

